{
  "expo": {
    "name": "Rimuru Music",
    "slug": "My_personal_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "assets/images/rimuru.png",
    "scheme": "mypersonalapp",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8f6f11d5-4af1-429e-8077-e5795aebdf74"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rimuru.musicplayer"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "assets/images/rimuru.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "package": "com.rimuru.musicplayer"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Rimuru Music to access your media.",
          "savePhotosPermission": "Allow Rimuru Music to save media."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "assets/images/rimuru.png",
          "resizeMode": "cover",
          "backgroundColor": "#000000"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8f6f11d5-4af1-429e-8077-e5795aebdf74"
      }
    }
  }
}
