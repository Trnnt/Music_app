{
  "expo": {
    "name": "Rimuru Music",
    "slug": "My_personal_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "assets/images/icon.png",
    "scheme": "mypersonalapp",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8f6f11d5-4af1-429e-8077-e5795aebdf74"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rimuru.musicplayer"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "assets/images/icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.rimuru.musicplayer",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "ACCESS_MEDIA_LOCATION",
        "FOREGROUND_SERVICE",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Rimuru Music to access your media.",
          "savePhotosPermission": "Allow Rimuru Music to save media.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-av",
      [
        "expo-splash-screen",
        {
        "image": "assets/images/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "enableProguardInReleaseBuilds": false
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "newArchEnabled": false,
    "hermesEnabled": false,
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8f6f11d5-4af1-429e-8077-e5795aebdf74"
      }
    }
  }
}
